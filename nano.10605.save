#!/bin/bash

# Start backend in the background
echo "Starting Node.js server..."
node server.js &

# Wait a few seconds for the server to start
sleep 3

# Start Ngrok and capture the public URL
echo "Starting Ngrok..."ççNGROK_OUTPUT=$(./ngrok http 3000 -region=eu --log=stdout | tee /dev/tty)

# Optional: extract the public URL automatically
PUBLIC_URL=$(echo "$NGROK_OUTPUT" | grep -o "https://[a-z0-9]*\.ngrok.io" | head -n 1)

echo "Your backend is publicly available at: $PUBLIC_URL"
